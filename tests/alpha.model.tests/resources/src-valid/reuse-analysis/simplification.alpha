package reuse.basic {
	
	affine sr_0 [N]->{ : 10<N }
		inputs 
			A, B, C : {[i] : 0<=i<3N}
		outputs
			Z : {[i,j] : 0<=i,j<N}
		let
			Z = reduce(min, (i,j,k->i,j), {:0<k} : 14[] + A[i+k] + B[i+j+k] + C[3N-i-k-1]);
	.
	
	affine sr_1 [N]->{ : 10<N }
		inputs 
			A, B, C : {[i] : 0<=i<3N}
		outputs
			Z : {[i,j] : 0<=i,j<N}
		locals
			L : {[i,j,k] : 0<=i,j,k<3N}
		let
			Z = reduce(min, (i,j,k->i,j), {:0<k} : 14[] + A[i+k] + L[i,j,k]);
			
			L[i,j,k] = B[i+j+k] + C[3N-i-k-1];
	.
	
}









