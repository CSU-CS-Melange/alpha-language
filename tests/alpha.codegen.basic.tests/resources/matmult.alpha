package basic.codegen.test {

affine matmult [N] -> { : N>0}
	inputs
		A : { [i,j] : 0<=i<N and 0<=j<N }
		B : { [i,j] : 0<=i<N and 0<=j<N } 
	outputs
		C : { [i,j,k] : 0<=i<N and 0<=j<N and 0<=k<N}
	let
		C[i,j,k] = case {
			{:k=0} : A[i,k] * B[k,j];
			{:k>0} : C[i,j,k-1] + A[i,k] * B[k,j];
		};
.

}
